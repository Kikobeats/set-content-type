{
  "name": "@kikobeats/set-content-type",
  "description": "Set the response content-type based on the payload bytes",
  "homepage": "https://github.com/kikobeats/set-content-type",
  "version": "0.0.0",
  "author": {
    "email": "josefrancisco.verdu@gmail.com",
    "name": "Jose Francisco 'Kiko' Verdú Gambín",
    "url": "https://kikobeats.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kikobeats/set-content-type.git"
  },
  "bugs": {
    "url": "https://github.com/kikobeats/set-content-type/issues"
  },
  "keywords": [
    "content-type",
    "detect",
    "file-type",
    "magic",
    "mime",
    "res",
    "response",
    "sniff",
    "stream"
  ],
  "dependencies": {
    "file-type": "~22.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "ava": "latest",
    "c8": "latest",
    "ci-publish": "latest",
    "conventional-changelog-cli": "latest",
    "finepack": "latest",
    "git-authors-cli": "latest",
    "github-generate-release": "latest",
    "nano-staged": "latest",
    "simple-git-hooks": "latest",
    "standard": "latest",
    "standard-version": "latest"
  },
  "engines": {
    "node": ">= 24"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "contributors": "(git-authors-cli && finepack && git add package.json && git commit -m 'build: contributors' --no-verify) || true",
    "coverage": "c8 report --reporter=text-lcov > coverage/lcov.info",
    "lint": "standard",
    "postrelease": "pnpm release:tags && pnpm release:github && (ci-publish || pnpm publish --access=public)",
    "pretest": "pnpm lint",
    "release": "pnpm release:version && pnpm release:changelog && pnpm release:commit && pnpm release:tag",
    "release:github": "github-generate-release",
    "release:tags": "git push origin HEAD:master --follow-tags",
    "test": "c8 ava",
    "release:changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "release:commit": "git add package.json CHANGELOG.md && git commit -m \"chore(release): $(node -p \"require('./package.json').version\")\"",
    "release:tag": "git tag -a v$(node -p \"require('./package.json').version\") -m \"v$(node -p \"require('./package.json').version\")\"",
    "release:version": "standard-version --skip.changelog --skip.commit --skip.tag"
  },
  "license": "MIT",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        0
      ]
    }
  },
  "exports": {
    ".": "./src/index.js"
  },
  "main": "./src/index.js",
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "nano-staged": {
    "*.js": [
      "npx @kikobeats/prettier-standard",
      "standard --fix"
    ],
    "package.json": [
      "finepack"
    ]
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --edit",
    "pre-commit": "npx nano-staged"
  }
}
